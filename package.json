{
  "name": "chesskit",
  "version": "0.1.0",
  "private": true,
  "license": "GPL-3.0-only",
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint --ext .ts,.tsx src/ && tsc --noEmit",
    "electron": "electron .",
    "electron-dev": "electron .",
    "electron-build": "node scripts/electron-build.mjs",
    "electron-pack": "npm run electron-build && electron-packager . Chesskit --platform=win32 --arch=x64 --out=dist-electron --icon=public/favicon.ico --overwrite --extra-resource=.electron-standalone --extra-resource=public/favicon.png --ignore=\"node_modules|src|\\.next|\\.electron-standalone|\\.git|dist-electron|data|scripts\"",
    "electron-installer": "npm run electron-build && electron-builder --win nsis",
    "make-icon": "node scripts/make-icon.mjs"
  },
  "build": {
    "appId": "app.chesskit.local",
    "productName": "Chesskit",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      "package.json",
      "!node_modules"
    ],
    "extraResources": [
      {
        "from": ".electron-standalone",
        "to": ".electron-standalone"
      },
      {
        "from": "public/favicon.png",
        "to": "icon.png"
      }
    ],
    "win": {
      "icon": "public/favicon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "sign": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Chesskit"
    }
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@fontsource/roboto": "^5.1.0",
    "@iconify/react": "^5.1.0",
    "@mui/lab": "^6.0.0-beta.21",
    "@mui/material": "^6.3.0",
    "@mui/x-data-grid": "^7.23.5",
    "@sentry/nextjs": "^10.48.0",
    "@tanstack/react-query": "^5.75.5",
    "chess.js": "^1.2.0",
    "firebase": "^11.1.0",
    "idb": "^8.0.1",
    "jotai": "^2.11.0",
    "next": "^16.2.6",
    "react": "19.2.5",
    "react-chessboard": "^4.7.3",
    "react-dom": "19.2.5",
    "recharts": "^2.15.0",
    "tinycolor2": "^1.6.0"
  },
  "devDependencies": {
    "@electron/packager": "^19.1.0",
    "@tanstack/eslint-plugin-query": "^5.74.7",
    "@types/node": "^22.10.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/tinycolor2": "^1.4.6",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "cross-env": "^7.0.3",
    "electron": "^41.2.2",
    "electron-builder": "^26.8.1",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.1.3",
    "eslint-config-prettier": "^8.10.0",
    "eslint-plugin-deprecation": "^3.0.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-prettier": "^5.2.1",
    "sharp": "^0.34.5",
    "typescript": "^5.7.2"
  }
}
